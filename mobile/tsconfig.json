{
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src",
    "App.js",
    "app.json",
    "index.js"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js"
  ],
  "extends": "expo/tsconfig.base"
}
